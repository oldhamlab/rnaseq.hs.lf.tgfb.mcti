# Snakefile
#
# Combined RNA-seq pipeline for MCTi (2022) and VB253 (2025) experiments.
# Downloads reads from ENA/SRA via kingfisher, builds a shared GENCODE/Salmon
# index, and quantifies all samples.
#
# Prerequisites:
#   Install Snakemake via miniforge/mamba (NOT Anaconda):
#     mamba env create -f data-raw/envs/snakemake.yaml
#     mamba activate snakemake
#
# Usage (from project root):
#   snakemake -s data-raw/Snakefile --sdm conda -c 7
#   snakemake -s data-raw/Snakefile --configfile data-raw/config.yaml --sdm conda -c 16 --rerun-triggers mtime
#
# Or launched from targets via system2().

import csv
import os

configfile: "data-raw/config.yaml"

# ---------------------------------------------------------------------------
# Sample manifest (generated by the targets pipeline from SRA run info)
# ---------------------------------------------------------------------------
with open(config["samples_tsv"]) as f:
    reader = csv.DictReader(f, delimiter="\t")
    _rows = list(reader)

SAMPLES = [row["sample_name"] for row in _rows]
SRR_MAP = {row["sample_name"]: row["run"] for row in _rows}

# ---------------------------------------------------------------------------
# Config refs
# ---------------------------------------------------------------------------
READS    = config["reads_dir"]
INDEX    = config["index_dir"]
QUANTS   = config["quants_dir"]
THREADS  = config["threads"]
GV       = str(config["gencode_version"])
DL_METHODS = config["download_methods"]

# Pre-compute reference file paths
TRANSCRIPTS_FA = os.path.join(INDEX, "gencode.v" + GV + ".transcripts.fa.gz")
GENOME_FA      = os.path.join(INDEX, "GRCh38.primary_assembly.genome.fa.gz")
ANNOTATION_GTF = os.path.join(INDEX, "gencode.v" + GV + ".annotation.gtf.gz")
DECOYS_TXT     = os.path.join(INDEX, "decoys.txt")
GENTROME_FA    = os.path.join(INDEX, "gentrome.fa.gz")
SALMON_IDX     = os.path.join(INDEX, "salmon_index")

GENCODE_BASE   = ("https://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/"
                   "release_" + GV)

# ---------------------------------------------------------------------------
# Target rule
# ---------------------------------------------------------------------------
rule all:
    input:
        expand(os.path.join(QUANTS, "{sample}", "quant.sf"), sample=SAMPLES),
        ANNOTATION_GTF

# ---------------------------------------------------------------------------
# Download reads via kingfisher
# ---------------------------------------------------------------------------
rule download_reads:
    output:
        r1 = os.path.join(READS, "{sample}_1.fastq.gz"),
        r2 = os.path.join(READS, "{sample}_2.fastq.gz")
    params:
        srr = lambda wc: SRR_MAP[wc.sample],
        outdir = READS,
        methods = DL_METHODS
    threads: THREADS
    retries: 3
    conda:
        "envs/kingfisher.yaml"
    shell:
        """
        mkdir -p {params.outdir}
        cd {params.outdir}
        rm -f {params.srr}_1.fastq.gz {params.srr}_2.fastq.gz {params.srr}*.aria2
        kingfisher get \
            -r {params.srr} \
            -m {params.methods} \
            -f fastq.gz \
            -t {threads}
        mv {params.srr}_1.fastq.gz {wildcards.sample}_1.fastq.gz
        mv {params.srr}_2.fastq.gz {wildcards.sample}_2.fastq.gz
        """

# ---------------------------------------------------------------------------
# GENCODE reference files
# ---------------------------------------------------------------------------
rule transcriptome:
    output:
        TRANSCRIPTS_FA
    params:
        outdir = INDEX,
        url = GENCODE_BASE + "/gencode.v" + GV + ".transcripts.fa.gz"
    conda:
        "envs/download.yaml"
    shell:
        """
        mkdir -p {params.outdir}
        wget -q {params.url} -P {params.outdir}
        """

rule genome:
    output:
        GENOME_FA
    params:
        outdir = INDEX,
        url = GENCODE_BASE + "/GRCh38.primary_assembly.genome.fa.gz"
    conda:
        "envs/download.yaml"
    shell:
        """
        mkdir -p {params.outdir}
        wget -q {params.url} -P {params.outdir}
        """

rule annotation:
    output:
        ANNOTATION_GTF
    params:
        outdir = INDEX,
        url = GENCODE_BASE + "/gencode.v" + GV + ".annotation.gtf.gz"
    conda:
        "envs/download.yaml"
    shell:
        """
        mkdir -p {params.outdir}
        wget -q {params.url} -P {params.outdir}
        """

rule decoys:
    input:
        genome = GENOME_FA
    output:
        DECOYS_TXT
    shell:
        """
        grep '^>' <(gunzip -c {input.genome}) | cut -d ' ' -f 1 | sed 's/>//g' \
            > {output}
        """

rule gentrome:
    input:
        transcripts = TRANSCRIPTS_FA,
        genome = GENOME_FA
    output:
        GENTROME_FA
    shell:
        "cat {input.transcripts} {input.genome} > {output}"

rule salmon_index:
    input:
        seq = GENTROME_FA,
        decoy = DECOYS_TXT
    output:
        directory(SALMON_IDX)
    threads: THREADS
    conda:
        "envs/salmon.yaml"
    shell:
        "salmon index --gencode -p {threads} -t {input.seq} -d {input.decoy} -i {output}"

# ---------------------------------------------------------------------------
# Salmon quantification
# ---------------------------------------------------------------------------
rule quant:
    input:
        r1 = os.path.join(READS, "{sample}_1.fastq.gz"),
        r2 = os.path.join(READS, "{sample}_2.fastq.gz"),
        index = SALMON_IDX
    output:
        os.path.join(QUANTS, "{sample}", "quant.sf")
    params:
        outdir = os.path.join(QUANTS, "{sample}")
    threads: THREADS
    conda:
        "envs/salmon.yaml"
    shell:
        "salmon quant -i {input.index} -l A -p {threads} --gcBias -o {params.outdir}"
        " -1 {input.r1} -2 {input.r2}"
