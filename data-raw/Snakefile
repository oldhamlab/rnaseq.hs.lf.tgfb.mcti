# Snakefile
#
# Combined RNA-seq pipeline for MCTi (2022) and VB253 (2025) experiments.
# Downloads reads from SRA, builds a shared GENCODE/Salmon index,
# and quantifies all samples.
#
# Prerequisites:
#   Install Snakemake via miniforge/mamba (NOT Anaconda):
#     mamba env create -f data-raw/envs/snakemake.yaml
#     mamba activate snakemake
#
# Usage (from project root):
#   snakemake -s data-raw/Snakefile --sdm conda -c 7
#
# Or launched from targets via system2().

import csv
import os

configfile: "data-raw/config.yaml"

# ---------------------------------------------------------------------------
# Sample manifest (generated by the targets pipeline from SRA run info)
# ---------------------------------------------------------------------------
with open(config["samples_tsv"]) as f:
    reader = csv.DictReader(f, delimiter="\t")
    _rows = list(reader)

SAMPLES = [row["sample_name"] for row in _rows]
SRR_MAP = {row["sample_name"]: row["run"] for row in _rows}

# ---------------------------------------------------------------------------
# Shorthand config refs
# ---------------------------------------------------------------------------
READS   = config["reads_dir"]
INDEX   = config["index_dir"]
QUANTS  = config["quants_dir"]
THREADS = config["threads"]
GV      = str(config["gencode_version"])

# Pre-compute reference file paths (avoids f-strings in rule blocks)
TRANSCRIPTS_FA = os.path.join(INDEX, "gencode.v" + GV + ".transcripts.fa.gz")
GENOME_FA      = os.path.join(INDEX, "GRCh38.primary_assembly.genome.fa.gz")
DECOYS_TXT     = os.path.join(INDEX, "decoys.txt")
GENTROME_FA    = os.path.join(INDEX, "gentrome.fa.gz")
SALMON_IDX     = os.path.join(INDEX, "salmon_index")

GENCODE_BASE   = ("ftp://ftp.ebi.ac.uk/pub/databases/gencode/Gencode_human/"
                   "release_" + GV)

# ---------------------------------------------------------------------------
# Target rule
# ---------------------------------------------------------------------------
rule all:
    input:
        expand(os.path.join(QUANTS, "{sample}", "quant.sf"), sample=SAMPLES)

# ---------------------------------------------------------------------------
# Download reads from SRA
# ---------------------------------------------------------------------------
rule prefetch:
    output:
        temp(os.path.join(READS, "sra", "{sample}.sra"))
    params:
        srr = lambda wc: SRR_MAP[wc.sample],
        outdir = os.path.join(READS, "sra")
    conda:
        "envs/sra-tools.yaml"
    shell:
        """
        mkdir -p {params.outdir}
        prefetch {params.srr} --output-file {output}
        """

rule fasterq_dump:
    input:
        os.path.join(READS, "sra", "{sample}.sra")
    output:
        r1 = os.path.join(READS, "{sample}_1.fq.gz"),
        r2 = os.path.join(READS, "{sample}_2.fq.gz")
    params:
        tmpdir = os.path.join(READS, "tmp"),
        r1_tmp = os.path.join(READS, "tmp", "{sample}_1.fastq"),
        r2_tmp = os.path.join(READS, "tmp", "{sample}_2.fastq")
    threads: THREADS
    conda:
        "envs/sra-tools.yaml"
    shell:
        """
        mkdir -p {params.tmpdir}
        fasterq-dump {input} \
            --outdir {params.tmpdir} \
            --outfile {wildcards.sample}.fastq \
            --threads {threads} \
            --split-files \
            --temp {params.tmpdir}
        pigz -c {params.r1_tmp} > {output.r1}
        pigz -c {params.r2_tmp} > {output.r2}
        rm -f {params.r1_tmp} {params.r2_tmp}
        """

# ---------------------------------------------------------------------------
# GENCODE reference files
# ---------------------------------------------------------------------------
rule transcriptome:
    output:
        TRANSCRIPTS_FA
    params:
        outdir = INDEX,
        url = GENCODE_BASE + "/gencode.v" + GV + ".transcripts.fa.gz"
    conda:
        "envs/download.yaml"
    shell:
        """
        mkdir -p {params.outdir}
        wget -q {params.url} -P {params.outdir}
        """

rule genome:
    output:
        GENOME_FA
    params:
        outdir = INDEX,
        url = GENCODE_BASE + "/GRCh38.primary_assembly.genome.fa.gz"
    conda:
        "envs/download.yaml"
    shell:
        """
        mkdir -p {params.outdir}
        wget -q {params.url} -P {params.outdir}
        """

rule decoys:
    input:
        genome = GENOME_FA
    output:
        DECOYS_TXT
    conda:
        "envs/salmon.yaml"
    shell:
        """
        grep '^>' <(gunzip -c {input.genome}) | cut -d ' ' -f 1 | sed 's/>//g' \
            > {output}
        """

rule gentrome:
    input:
        transcripts = TRANSCRIPTS_FA,
        genome = GENOME_FA
    output:
        GENTROME_FA
    shell:
        "cat {input.transcripts} {input.genome} > {output}"

rule salmon_index:
    input:
        seq = GENTROME_FA,
        decoy = DECOYS_TXT
    output:
        directory(SALMON_IDX)
    threads: THREADS
    conda:
        "envs/salmon.yaml"
    shell:
        "salmon index --gencode -p {threads} -t {input.seq} -d {input.decoy} -i {output}"

# ---------------------------------------------------------------------------
# Salmon quantification
# ---------------------------------------------------------------------------
rule quant:
    input:
        r1 = os.path.join(READS, "{sample}_1.fq.gz"),
        r2 = os.path.join(READS, "{sample}_2.fq.gz"),
        index = SALMON_IDX
    output:
        os.path.join(QUANTS, "{sample}", "quant.sf")
    params:
        outdir = os.path.join(QUANTS, "{sample}")
    threads: THREADS
    conda:
        "envs/salmon.yaml"
    shell:
        "salmon quant -i {input.index} -l A -p {threads} --gcBias -o {params.outdir}"
        " -1 {input.r1} -2 {input.r2}"
